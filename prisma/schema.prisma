generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH ====================

model Customer {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  phone         String?
  avatar        String?
  emailVerified Boolean   @default(false)
  googleId      String?   @unique
  provider      String    @default("email")
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  orders        Order[]
  refreshTokens RefreshToken[]
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([code])
  @@index([expiresAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  customerId String
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([customerId])
}

// ==================== ADMIN ====================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== BUSINESS ====================

model Consultation {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  country   String?
  service   String
  message   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Hospital {
  id          String   @id @default(cuid())
  name        String
  nameEn      String?
  nameZh      String?
  city        String
  specialty   String[]
  description String?
  imageUrl    String?
  address     String?
  phone       String?
  website     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  services    Service[]
  products    Product[]

  @@index([city])
  @@index([active])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  category    String
  priceUsd    Decimal?
  priceCny    Decimal?
  description String?
  features    String[]
  hospitalId  String?
  hospital    Hospital? @relation(fields: [hospitalId], references: [id])
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([active])
}

model Product {
  id            String   @id @default(cuid())
  name          String
  category      String
  originalPrice Float    @default(0)
  currentPrice  Float    @default(0)
  days          Int      @default(0)
  description   String?
  features      String[]
  includes      String[]
  schedule      String[]
  hospitalId    String?
  hospital      Hospital? @relation(fields: [hospitalId], references: [id])
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]

  @@index([category])
  @@index([active])
}

model Order {
  id          String   @id @default(cuid())
  orderNo     String   @unique
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  amount      Float
  status      String   @default("pending")
  notes       String?
  contactName String?
  contactPhone String?
  contactEmail String?
  expectedDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([customerId])
}

model Translation {
  id        String   @id @default(cuid())
  key       String
  locale    String
  value     String
  section   String
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
  @@index([locale])
}

model Config {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
